# Blog Publisher Service — configuration template.
#
# Values are intentionally left blank. Fill them in via your deployment's
# config / secret mechanism. Do not commit a populated copy.
#
# See docs/operations.md ("Configuration template") for the non-secret /
# secret split.

# ──────────────────────────────────────────────────────────────────
# HTTP server
# ──────────────────────────────────────────────────────────────────
PORT=3000
# Bearer token plugin (slack-bot) and Service share. Generated with
# `openssl rand -hex 32`.
BEARER_TOKEN=

# ──────────────────────────────────────────────────────────────────
# Obsidian LiveSync (CouchDB)
# ──────────────────────────────────────────────────────────────────
# Vault prefix the Service treats as publishable. Notes outside this
# subtree are never listed.
NOTES_PATH_PREFIX=notes/blogs/
COUCHDB_URL=
COUCHDB_USERNAME=
COUCHDB_PASSWORD=
COUCHDB_DATABASE=
# LiveSync E2EE passphrase (chunk-level encryption). Path Obfuscation and
# Property Encryption MUST be disabled in the vault settings; the Service
# fails fast at startup otherwise.
LIVESYNC_PASSPHRASE=

# ──────────────────────────────────────────────────────────────────
# GitHub (commits + PRs against fohte/fohte.net)
# ──────────────────────────────────────────────────────────────────
GITHUB_OWNER=fohte
GITHUB_REPO=fohte.net
GITHUB_DEFAULT_BRANCH=master

# ──────────────────────────────────────────────────────────────────
# octo-sts (short-lived GitHub App installation tokens)
# ──────────────────────────────────────────────────────────────────
# The Service authenticates by exchanging a Pod ServiceAccount token
# at octo-sts for a 1-hour installation token (no long-lived App
# Private Key is stored on the Service). The SA token is mounted as a
# projected volume by the K8s manifest.
OCTO_STS_URL=https://octo-sts.fohte.net
OCTO_STS_SCOPE=fohte/fohte.net
OCTO_STS_IDENTITY=fohte.net-blog-publisher
OCTO_STS_SA_TOKEN_PATH=/var/run/secrets/tokens/octo-sts-token

# ──────────────────────────────────────────────────────────────────
# Cloudflare R2 (image variants)
# ──────────────────────────────────────────────────────────────────
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Comma-separated webp variant widths. Sources narrower than a given
# width are skipped for that variant.
IMAGE_VARIANT_WIDTHS=640,1280,1920
